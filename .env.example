# ── Slidd.app ───────────────────────────────────────────────────────────────────────
APP_NAME=Slidd
APP_ENV=local
APP_KEY=
APP_DEBUG=true    # false in production
APP_URL=http://localhost

DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=sync

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@slidd.app"
MAIL_FROM_NAME="${APP_NAME}"

LOG_CHANNEL=stack
LOG_LEVEL=debug
